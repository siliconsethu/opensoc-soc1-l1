#!/bin/sh
# eclass_sim -- auto-selects Python and runs scripts/eclass_sim.py
# Usage: ./eclass_sim gpio_l1 [--gui] [--waves] [--clean] [--verbose]
REPO="$(cd "$(dirname "$0")" && pwd)"
for v in python3.12 python3.11 python3.10 python3.9 python3.8 python3; do
    if command -v "$v" >/dev/null 2>&1; then
        exec "$v" "$REPO/scripts/eclass_sim.py" "$@"
    fi
done
echo "[ERROR] Python 3 not found. Install python3 or add it to PATH." >&2
exit 1
