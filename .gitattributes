# Ensure consistent LF line endings for text files
* text=auto
*.sv  text eol=lf
*.svh text eol=lf
*.f   text eol=lf
*.c   text eol=lf
*.S   text eol=lf
*.h   text eol=lf
*.ld  text eol=lf
*.py  text eol=lf
*.tcl text eol=lf
*.sdc text eol=lf
*.xdc text eol=lf
Makefile text eol=lf
*.md  text eol=lf

# Binary files
*.docx binary
*.wlf  binary
*.ucdb binary
